        "status": "completed",
        "objectivesJson": "[{\"text\":\"สืบหาเบาะแสที่ตลาด\",\"checked\":true},{\"text\":\"ตามรอยไปยังถ้ำโจร\",\"checked\":true},{\"text\":\"ช่วยมาร์คัสกลับมา\",\"checked\":true}]",
