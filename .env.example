# Copy to .env and adjust as needed.

# SQLite file database (local, single-host). Relative to /prisma.
DATABASE_URL="file:./dev.db"

# Port the single Node process (Next + Socket.io) listens on. Players join at http://<dm-ip>:PORT
PORT=3000

# AI DM Assistant (Sprint 7) — local Ollama. Optional: app runs fully without it
# (generation disabled, Import still works). Probed once at boot.
# Host of the local Ollama server.
OLLAMA_HOST="http://localhost:11434"
# Model to generate with. Must be pulled first: `ollama pull <model>`.
# Provider default is qwen2.5:14b; override here to match what you pulled.
OLLAMA_MODEL="llama3.1:8b"
